<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Configurable Premium Background -->
    <ImageView
        android:id="@+id/widget_bg_shape"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_card_bg" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Logo and Metadata Row on the Left -->
        <LinearLayout
            android:id="@+id/widget_meta_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/widget_controls_container"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">

            <!-- Logo ImageView -->
            <ImageView
                android:id="@+id/widget_logo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="10dp"
                android:scaleType="fitCenter"
                android:background="@drawable/widget_logo_bg"
                android:src="@drawable/ic_radio" />

            <!-- Title & Info Stack -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="AltaVox Radio"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="MP3 • 128 kbps"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Controls Row on the Right -->
        <LinearLayout
            android:id="@+id/widget_controls_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Previous Button -->
            <ImageView
                android:id="@+id/widget_btn_prev"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:scaleType="fitCenter"
                android:padding="7dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_widget_prev" android:tint="@color/widget_icon_tint" />

            <!-- Play/Pause Button -->
            <ImageView
                android:id="@+id/widget_btn_play_pause"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:scaleType="fitCenter"
                android:padding="3dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_widget_play" android:tint="@color/widget_icon_tint" />

            <!-- Next Button -->
            <ImageView
                android:id="@+id/widget_btn_next"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:scaleType="fitCenter"
                android:padding="7dp"
                android:src="@drawable/ic_widget_next" android:tint="@color/widget_icon_tint" />
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>



