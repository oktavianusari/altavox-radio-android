<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Configurable Premium Background -->
    <ImageView
        android:id="@+id/widget_bg_shape"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_card_bg" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- UPPER SECTION (same as Big Widget) -->
        <RelativeLayout
            android:id="@+id/widget_upper_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true">

            <!-- Large Premium Rounded Logo Artwork on Left -->
            <ImageView
                android:id="@+id/widget_logo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:scaleType="fitCenter"
                android:background="@drawable/widget_logo_bg"
                android:src="@drawable/ic_radio" />

            <!-- Metadata and Play Controls Column on the Right -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/widget_logo"
                android:layout_marginStart="14dp">

                <!-- Title & Artist/Bitrate Metadata Container -->
                <LinearLayout
                    android:id="@+id/widget_meta_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="AltaVox Radio"
                        android:textColor="@color/widget_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_artist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="MP3 • 128 kbps"
                        android:textColor="@color/widget_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Playback Control Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_below="@id/widget_meta_container"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <!-- Previous Button -->
                    <ImageView
                        android:id="@+id/widget_btn_prev"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_widget_prev" android:tint="@color/widget_icon_tint" />

                    <!-- Play/Pause Button -->
                    <ImageView
                        android:id="@+id/widget_btn_play_pause"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="fitCenter"
                        android:padding="4dp"
                        android:src="@drawable/ic_widget_play" android:tint="@color/widget_icon_tint" />

                    <!-- Next Button -->
                    <ImageView
                        android:id="@+id/widget_btn_next"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_widget_next" android:tint="@color/widget_icon_tint" />

                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>

        <!-- BOTTOM FAVOURITES BOX - 5 circular logo icons -->
        <LinearLayout
            android:id="@+id/widget_bottom_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/widget_bottom_card_bg"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/widget_fav_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="FAVOURITES"
                android:textColor="#3D92FF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <!-- 5 circular icon slots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:weightSum="5">

                <!-- Fav 1 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/widget_fav_1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:src="@drawable/ic_radio" />
                </FrameLayout>

                <!-- Fav 2 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/widget_fav_2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:src="@drawable/ic_radio" />
                </FrameLayout>

                <!-- Fav 3 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/widget_fav_3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:src="@drawable/ic_radio" />
                </FrameLayout>

                <!-- Fav 4 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/widget_fav_4"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:src="@drawable/ic_radio" />
                </FrameLayout>

                <!-- Fav 5 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/widget_fav_5"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:src="@drawable/ic_radio" />
                </FrameLayout>

            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>
</FrameLayout>



