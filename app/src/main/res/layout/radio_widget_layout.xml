<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Configurable Premium Background -->
    <ImageView
        android:id="@+id/widget_bg_shape"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_card_bg" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- UPPER SECTION -->
        <RelativeLayout
            android:id="@+id/widget_upper_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true">

            <!-- Large Premium Rounded Logo Artwork on Left -->
            <ImageView
                android:id="@+id/widget_background"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:scaleType="fitCenter"
                android:background="@drawable/widget_logo_bg"
                android:src="@drawable/ic_radio" />

            <!-- Metadata and Play Controls Column on the Right (Fills remaining width) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/widget_background"
                android:layout_marginStart="14dp">

                <!-- Title & Artist/Bitrate Metadata Container -->
                <LinearLayout
                    android:id="@+id/widget_meta_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="AltaVox Radio"
                        android:textColor="@color/widget_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/widget_artist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="MP3 • 128 kbps"
                        android:textColor="@color/widget_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Playback Control Buttons Row (Spans full available width to eliminate empty space) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_below="@id/widget_meta_container"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <!-- Previous Button Column Zone (Takes exactly 1/3 of the right section width) -->
                    <ImageView
                        android:id="@+id/widget_btn_prev"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_widget_prev" />

                    <!-- Play/Pause Button Column Zone (Takes exactly 1/3 of the right section width) -->
                    <ImageView
                        android:id="@+id/widget_btn_play_pause"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="fitCenter"
                        android:padding="4dp"
                        android:src="@drawable/ic_widget_play" />

                    <!-- Next Button Column Zone (Takes exactly 1/3 of the right section width) -->
                    <ImageView
                        android:id="@+id/widget_btn_next"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_widget_next" />

                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>

        <!-- BOTTOM FAVOURITES BOX -->
        <LinearLayout
            android:id="@+id/widget_bottom_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/widget_bottom_card_bg"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/widget_fav_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="FAVOURITES"
                android:textColor="@color/widget_fav_header"
                android:textSize="9sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Favourites Quick Play Item 1 (48dp height for effortless tapping) -->
                <LinearLayout
                    android:id="@+id/widget_fav_item_1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/widget_fav_chip_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:id="@+id/widget_fav_1_logo"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:padding="0.5dp"
                        android:src="@drawable/ic_radio" />

                    <TextView
                        android:id="@+id/widget_fav_1_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Sonora FM"
                        android:textColor="@color/widget_fav_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Favourites Quick Play Item 2 (48dp height for effortless tapping) -->
                <LinearLayout
                    android:id="@+id/widget_fav_item_2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/widget_fav_chip_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:id="@+id/widget_fav_2_logo"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/widget_fav_chip_bg"
                        android:padding="0.5dp"
                        android:src="@drawable/ic_radio" />

                    <TextView
                        android:id="@+id/widget_fav_2_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Kis FM"
                        android:textColor="@color/widget_fav_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>

