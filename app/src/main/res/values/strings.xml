    <!-- Help Content Strings -->
    <string name="help_intro_title">AltaVox Radio - Help &amp; Features</string>
    <string name="help_intro_body">Welcome to AltaVox Radio! Below is a detailed explanation of the features available in this application.</string>
    
    <string name="help_streaming_title">1. Radio Streaming &amp; Custom Playlists</string>
    <string name="help_streaming_body">The app streams standard live feeds seamlessly. You can customize the source list using remote M3U URL playlists. These are synced, saved, and categorized directly within the app.</string>
    
    <string name="help_widgets_title">2. Home Screen Widgets</string>
    <string name="help_widgets_body">AltaVox Radio offers two widget choices:\n• Big Widget: Shows the currently playing radio logo, details, previous/next controls, and dynamic quick-play buttons for your top 2 favorite stations.\n• Small Widget: A sleek, horizontal bar with essential controls `[Prev] [Play/Pause] [Next]`, designed to fit anywhere.</string>
    
    <string name="help_widget_styles_title">3. Dynamic Widget Customization</string>
    <string name="help_widget_styles_body">Modify background tint colors and transparency (opacity) levels for each widget type directly under Widget Settings. Changes apply instantly, letting you personalize your Android launcher aesthetic.</string>
    
    <string name="help_search_title">4. Spotify-Style Search</string>
    <string name="help_search_body">Tap the Search bar at the top of the main screen. Typing filters the station list dynamically across both radio station names and categories, offering a fast, responsive, and seamless search experience.</string>
    
    <string name="help_localization_title">5. Multi-Language Support</string>
    <string name="help_localization_body">Switch the entire application interface between English and Bahasa Indonesia. The change applies dynamically and immediately across the entire workspace.</string>
    
    <string name="help_advanced_title">6. Buffering &amp; Custom Theme Styling</string>
    <string name="help_advanced_body">Customize accent colors for light and dark themes using color pickers. For slow network connections, toggle Use Larger Buffer under Advanced Playback to reduce audio skipping and dropouts.</string>
    
    <string name="widget_settings_warning">Note: Changing widget color or opacity might pause streaming. You can resume playback after you are done adjusting.</string>
