    <!-- Help Content Strings -->
    <string name="help_intro_title">AltaVox Radio - Help &amp; Features</string>
    <string name="help_intro_body">Your ultimate, ad-free, minimal internet radio experience. Below is some information about the features of this app.</string>
    <string name="help_playback_title">1. Radio Playback</string>
    <string name="help_playback_body">Supports background streaming playback with an elegant Now Playing Bar and Notification controls.</string>
    <string name="help_management_title">2. Radio List Management</string>
    <string name="help_management_body">Add stations manually, bulk delete multiple stations, or update your entire list automatically from an online M3U file.</string>
    <string name="help_widgets_title">3. Interactive Widgets</string>
    <string name="help_widgets_body">Provides 3 distinct widgets (Compact, Wide, and Favourites) to control your radio from the home screen. Widget color and opacity are fully customizable.</string>
    <string name="help_search_title">4. Search &amp; Filter</string>
    <string name="help_search_body">Easily find your favorite radio stations using the smart search box that filters the list instantly as you type.</string>
    <string name="help_theme_title">5. Theme Adaptation</string>
    <string name="help_theme_body">The interface automatically adapts to your system\'s dark and light mode, providing a comfortable viewing experience at all times.</string>
    <string name="help_localization_title">6. Bilingual Support</string>
    <string name="help_localization_body">Choose between English and Indonesian, and the app will instantly adjust its language across all menus and dialogs.</string>
    
    <string name="widget_settings_warning">Note: Changing widget color or opacity might pause streaming. You can resume playback after you are done adjusting.</string>
